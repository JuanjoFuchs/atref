{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "atref",
  "version": "0.5.0",
  "identifier": "dev.atref.picker",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "atref",
        "width": 720,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "radius": 12
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
